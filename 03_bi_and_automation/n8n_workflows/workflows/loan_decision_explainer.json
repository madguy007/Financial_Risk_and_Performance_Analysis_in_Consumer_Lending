    {
      "parameters": {
        "jsCode": "const loan = $input.first().json;\n\nlet risk_factors = [];\n\n// Rule-based risk detection\n\nif (loan.dti > 30) {\n  risk_factors.push(\"High debt-to-income ratio\");\n}\n\nif (loan.interest_rate > 15) {\n  risk_factors.push(\"High interest rate\");\n}\n\nif (loan.income_cat === \"Low\") {\n  risk_factors.push(\"Low income category\");\n}\n\nif (loan.emp_length_int < 2) {\n  risk_factors.push(\"Short employment history\");\n}\n\nif ([\"D\", \"E\", \"F\"].includes(loan.grade)) {\n  risk_factors.push(\"High-risk loan grade\");\n}\n\n// Return structured output\nreturn [{\n  json: {\n    loan_id: loan.id,\n    loan_status: loan.loan_condition,\n    risk_factors: risk_factors,\n    loan_data: loan\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        416,
        0
      ],
      "id": "0a3d7916-c719-40f8-bc2d-fb58289daa8c",
      "name": "Code in JavaScript"
    },
    {
      "parameters": {
        "promptType": "define",
        "text": "=You are a financial risk analyst.\n\nLoan status: {{$json.loan_status}}\n\nRisk factors:\n{{$json.risk_factors.join(\", \")}}\n\nLoan details:\n- DTI: {{$json.loan_data.dti}}\n- Interest Rate: {{$json.loan_data.interest_rate}}\n- Income Category: {{$json.loan_data.income_cat}}\n- Employment Length: {{$json.loan_data.emp_length_int}} years\n- Grade: {{$json.loan_data.grade}}\n\nExplain briefly (2–3 sentences) why this loan is {{$json.loan_status}}.\nUse simple, clear business language.",
        "messages": {
