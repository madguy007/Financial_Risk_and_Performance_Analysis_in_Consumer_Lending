        "query": "SELECT \n    id,\n    grade,\n    interest_rate,\n    dti,\n    income_cat,\n    emp_length_int,\n    purpose,\n    loan_condition\nFROM loan_cleaned\nWHERE id = {{ $json.body.loan_id }}\nLIMIT 1;",
