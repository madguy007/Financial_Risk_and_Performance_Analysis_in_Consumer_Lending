    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT\n    COUNT(*) AS total_loans,\n    \n    ROUND(100.0 * SUM(CASE WHEN loan_condition = 'BAD LOAN' THEN 1 ELSE 0 END) / COUNT(*), 2) AS bad_loan_pct,\n    \n    ROUND(100.0 * SUM(CASE WHEN grade IN ('D','E','F') THEN 1 ELSE 0 END) / COUNT(*), 2) AS high_risk_pct,\n    \n    ROUND(AVG(interest_rate), 2) AS avg_interest_rate\nFROM loan_cleaned;",
        "options": {}
      },
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.6,
      "position": [
        992,
        0
      ],
