    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT\n    region,\n    ROUND(\n        100.0 * SUM(CASE WHEN loan_condition = 'BAD LOAN' THEN 1 ELSE 0 END) \n        / COUNT(*), 2\n    ) AS default_pct\nFROM loan_cleaned\nGROUP BY region\nORDER BY default_pct DESC;",
